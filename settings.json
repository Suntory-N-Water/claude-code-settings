{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 999,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "skillOverrides": {
    "claude-api": "off",
    "deep-research": "off",
    "schedule": "off",
    "run": "off",
    "loop": "off",
    "verify": "off",
    "keybindings-help": "off",
    "fewer-permission-prompts": "off",
    "init": "off"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run -i --silent ~/.claude/scripts/typescript/create-plan-link.ts"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bun run -i --silent ~/.claude/scripts/typescript/plan-mode-style.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Explore|general-purpose",
        "hooks": [
          {
            "type": "command",
            "command": "bun run -i --silent ~/.claude/scripts/typescript/subagent-archive.ts"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run -i --silent ~/.claude/scripts/typescript/tool-failure-log.ts"
          }
        ]
      }
    ]
  },
  "disableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.py"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "suntory-n-water-marketplace": {
      "source": {
        "source": "github",
        "repo": "Suntory-N-Water/suntory-n-water-marketplace"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "environment": [
      "$defaults"
    ]
  }
}
